#!/usr/bin/env python3
"""
Automatically switch OpenClaw between desktop GPU and server CPU fallback
based on whether the desktop Ollama is reachable.

Run via cron every 2-3 minutes.
"""

import json
import subprocess
import sys
import urllib.request
import urllib.error
from datetime import datetime

CONFIG_PATH = "/opt/containers/openclaw/config/openclaw.json"
AGENT_MODELS_PATH = "/opt/containers/openclaw/config/agents/main/agent/models.json"
COMPOSE_DIR = "/opt/containers/openclaw"

DESKTOP = {
    "baseUrl": "http://100.74.78.70:11434",
    "modelId": "qwen2.5:7b",
    "modelName": "Qwen 2.5 7B",
    "contextWindow": 32768,
    "maxTokens": 32768,
}

SERVER = {
    "baseUrl": "http://192.168.68.16:11434",
    "modelId": "qwen2.5:1.5b-ctx32k",
    "modelName": "Qwen 2.5 1.5B (server fallback)",
    "contextWindow": 32768,
    "maxTokens": 32768,
}


def log(msg):
    print(f"[{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}] {msg}", flush=True)


def desktop_reachable():
    try:
        req = urllib.request.urlopen(
            f"{DESKTOP['baseUrl']}/api/tags", timeout=5
        )
        return req.status == 200
    except Exception:
        return False


def read_config(path):
    with open(path) as f:
        return json.load(f)


def write_config(path, config):
    with open(path, "w") as f:
        json.dump(config, f, indent=2)
    subprocess.run(["chown", "1000:1000", path], check=True)


def get_current_model(config):
    return config["agents"]["defaults"]["model"]["primary"]


def apply_target(target):
    model_entry = {
        "id": target["modelId"],
        "name": target["modelName"],
        "reasoning": False,
        "input": ["text"],
        "cost": {"input": 0, "output": 0, "cacheRead": 0, "cacheWrite": 0},
        "contextWindow": target["contextWindow"],
        "maxTokens": target["maxTokens"],
    }

    # Update main config
    config = read_config(CONFIG_PATH)
    config["models"]["providers"]["ollama"]["baseUrl"] = target["baseUrl"]
    config["models"]["providers"]["ollama"]["models"] = [model_entry]
    config["agents"]["defaults"]["model"]["primary"] = f"ollama/{target['modelId']}"
    write_config(CONFIG_PATH, config)

    # Update agent-level models.json
    agent_models = read_config(AGENT_MODELS_PATH)
    agent_models["providers"]["ollama"]["baseUrl"] = target["baseUrl"]
    agent_models["providers"]["ollama"]["models"] = [{**model_entry, "api": "ollama"}]
    write_config(AGENT_MODELS_PATH, agent_models)


def restart_gateway():
    subprocess.run(
        ["docker-compose", "restart", "openclaw-gateway"],
        cwd=COMPOSE_DIR,
        check=True,
        capture_output=True,
    )


def main():
    config = read_config(CONFIG_PATH)
    current = get_current_model(config)
    reachable = desktop_reachable()

    on_desktop = current == f"ollama/{DESKTOP['modelId']}"
    on_server = current == f"ollama/{SERVER['modelId']}"

    if reachable and on_desktop:
        log(f"Desktop reachable, already on desktop model — no change.")
        return
    if not reachable and on_server:
        log(f"Desktop unreachable, already on server fallback — no change.")
        return

    if reachable and not on_desktop:
        log(f"Desktop came back online. Switching from {current} → {DESKTOP['modelId']}")
        apply_target(DESKTOP)
        restart_gateway()
        log("Switched to desktop GPU model.")
    elif not reachable and not on_server:
        log(f"Desktop unreachable. Switching from {current} → {SERVER['modelId']}")
        apply_target(SERVER)
        restart_gateway()
        log("Switched to server CPU fallback.")


if __name__ == "__main__":
    try:
        main()
    except Exception as e:
        log(f"ERROR: {e}")
        sys.exit(1)
